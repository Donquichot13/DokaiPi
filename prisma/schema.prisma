// Prisma schema — CRM implementation in Phase 7
// Run: pnpm prisma:generate after updating this file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder model — replaced with full CRM schema in Phase 7
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("users")
}

// Quote — added in Phase 4; extended with relations in Phase 7
model Quote {
  id           String      @id @default(cuid())
  quoteNumber  String      @unique // Q-YYYY-NNNN
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Contact
  name         String
  email        String
  phone        String?
  company      String?
  website      String?
  message      String?
  howDidYouHear String

  // Pricing snapshot (JSON — never recalculate from relations)
  projectType    String
  features       Json      // string[]
  modifiers      Json      // string[]
  priceBreakdown Json      // PriceBreakdown

  // Admin workflow
  status         QuoteStatus @default(PENDING)
  adminNote      String?

  @@map("quotes")
}

enum QuoteStatus {
  PENDING
  REVIEWED
  SENT
  ACCEPTED
  REJECTED
  ARCHIVED
}
