# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dokaipi"

# NextAuth v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Admin credentials (used by seed.ts)
SEED_ADMIN_EMAIL="admin@dokaipi.fr"
SEED_ADMIN_PASSWORD="change-me-in-production"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
ADMIN_EMAIL="admin@dokaipi.fr"
FROM_EMAIL="DokaiPi <noreply@dokaipi.fr>"

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
